<div id="svg-optimizer-tool" class="tool-content hidden">
    <div class="mb-6">
        <h2 class="text-2xl font-bold text-stone-200 mb-2">SVG Optimizer</h2>
        <p class="text-stone-400">Optimize and minify SVG files by removing unnecessary elements, comments, and whitespace.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Input Section -->
        <div class="space-y-4">
            <div>
                <label for="svg-input" class="block text-sm font-medium text-stone-300 mb-2">Input SVG</label>
                <textarea id="svg-input" rows="12" placeholder="Paste your SVG code here..."
                    class="w-full p-4 border border-stone-600 bg-stone-700 text-stone-200 rounded-lg resize-y font-mono text-sm"></textarea>
            </div>

            <div class="flex flex-col sm:flex-row gap-3">
                <button id="optimize-svg-btn" onclick="optimizeSvg()"
                    class="flex-1 px-6 py-3 bg-sky-600 hover:bg-sky-500 text-white font-medium rounded-lg transition-colors">
                    Optimize SVG
                </button>
                <button id="clear-svg-btn" onclick="clearSvgInputs()"
                    class="px-6 py-3 bg-stone-600 hover:bg-stone-500 text-white font-medium rounded-lg transition-colors">
                    Clear
                </button>
            </div>

            <!-- File Upload -->
            <div class="border-2 border-dashed border-stone-600 rounded-lg p-4 hover:border-stone-500 transition-colors">
                <input type="file" id="svg-file-input" accept=".svg" class="hidden" onchange="handleSvgFileUpload(this)">
                <label for="svg-file-input" class="cursor-pointer flex flex-col items-center space-y-2">
                    <svg class="w-8 h-8 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                    </svg>
                    <span class="text-stone-300 text-sm">Click to upload SVG file</span>
                    <span class="text-stone-500 text-xs">or drag and drop here</span>
                </label>
            </div>
        </div>

        <!-- Output Section -->
        <div class="space-y-4">
            <div>
                <label for="svg-output" class="block text-sm font-medium text-stone-300 mb-2">Optimized SVG</label>
                <textarea id="svg-output" rows="12" readonly placeholder="Optimized SVG will appear here..."
                    class="w-full p-4 border border-stone-600 bg-stone-700 text-stone-200 rounded-lg resize-y font-mono text-sm"></textarea>
            </div>

            <div class="flex flex-col sm:flex-row gap-3">
                <button id="copy-svg-btn" onclick="copySvgToClipboard()" disabled class="flex-1 px-6 py-3 bg-green-600 hover:bg-green-500
                    disabled:bg-stone-600 disabled:cursor-not-allowed text-white font-medium rounded-lg transition-colors">
                    Copy to Clipboard
                </button>
                <button id="download-svg-btn" onclick="downloadOptimizedSvg()" disabled class="px-6 py-3 bg-blue-600 hover:bg-blue-500
                    disabled:bg-stone-600 disabled:cursor-not-allowed text-white font-medium rounded-lg transition-colors">
                    Download
                </button>
            </div>

            <!-- Stats -->
            <div id="optimization-stats" class="hidden bg-stone-900/50 rounded-lg p-4">
                <h4 class="text-sm font-medium text-stone-300 mb-2">Optimization Results</h4>
                <div class="grid grid-cols-2 gap-4 text-sm">
                    <div>
                        <span class="text-stone-400">Original Size:</span>
                        <span id="original-size" class="text-stone-200 ml-2 font-mono"></span>
                    </div>
                    <div>
                        <span class="text-stone-400">Optimized Size:</span>
                        <span id="optimized-size" class="text-stone-200 ml-2 font-mono"></span>
                    </div>
                    <div>
                        <span class="text-stone-400">Saved:</span>
                        <span id="saved-size" class="text-green-400 ml-2 font-mono"></span>
                    </div>
                    <div>
                        <span class="text-stone-400">Compression:</span>
                        <span id="compression-ratio" class="text-green-400 ml-2 font-mono"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Loading State -->
    <div id="svg-loading" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
        <div class="bg-stone-800 rounded-lg p-6 flex items-center space-x-3">
            <svg class="animate-spin w-5 h-5 text-sky-400" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962
                    7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span class="text-stone-200">Optimizing SVG...</span>
        </div>
    </div>

    <!-- Preview Section -->
    <div class="mt-8">
        <h3 class="text-lg font-semibold text-stone-200 mb-4">SVG Preview</h3>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div>
                <h4 class="text-sm font-medium text-stone-300 mb-2">Original</h4>
                <div id="original-svg-preview" class="w-full h-64 border border-stone-600 bg-white rounded-lg flex items-center justify-center">
                    <span class="text-stone-400 text-sm">Original SVG preview will appear here</span>
                </div>
            </div>
            <div>
                <h4 class="text-sm font-medium text-stone-300 mb-2">Optimized</h4>
                <div id="optimized-svg-preview" class="w-full h-64 border border-stone-600 bg-white rounded-lg flex items-center justify-center">
                    <span class="text-stone-400 text-sm">Optimized SVG preview will appear here</span>
                </div>
            </div>
        </div>
    </div>
</div>
